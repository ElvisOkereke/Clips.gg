{
  "productName": "ClipLite",
  "version": "1.0.0",
  "identifier": "com.cliplite.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ClipLite",
        "width": 600,
        "height": 696,
        "minWidth": 420,
        "minHeight": 522,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true,
        "label": "main",
        "additionalBrowserArgs": "--disable-gpu --disable-software-rasterizer --disable-gpu-compositing"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["bin/*"],
    "windows": {
      "wix": {},
      "nsis": {}
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
